<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Analizador de Pedimentos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0C1E35;
    --navy-light: #142840;
    --gold: #C8963E;
    --gold-light: #F5EDE0;
    --gold-dim: rgba(200,150,62,.12);
    --bg: #F3F4F7;
    --surface: #FFFFFF;
    --text: #1B2838;
    --text-secondary: #64748B;
    --border: #E2E6ED;
    --amber-bg: #FEF8EC;
    --amber-border: #F0D78C;
    --green: #1A7F4B;
    --red-soft: #DC4A4A;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  /* ── Top bar ── */
  .topbar {
    background: var(--navy);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    height: 56px;
    border-bottom: 3px solid var(--gold);
  }
  .topbar h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    color: #fff;
    letter-spacing: .02em;
  }
  .topbar h1 span {
    color: var(--gold);
    margin-right: .5rem;
  }

  .main { max-width: 1140px; margin: 0 auto; padding: 2rem 1.5rem 3rem; }

  /* ── Upload ── */
  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 10px;
    padding: 2.5rem 2rem;
    text-align: center;
    cursor: pointer;
    background: var(--surface);
    transition: border-color .2s, background .2s, box-shadow .2s;
    position: relative;
    max-width: 560px;
    margin: 0 auto;
  }
  .upload-zone:hover { border-color: #a0aec0; }
  .upload-zone.dragover {
    border-color: var(--gold);
    background: var(--gold-dim);
    box-shadow: 0 0 0 4px rgba(200,150,62,.08);
  }
  .upload-zone input { display: none; }
  .upload-icon {
    width: 48px; height: 48px; margin: 0 auto 1rem;
    background: var(--gold-dim);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
  }
  .upload-icon svg { width: 24px; height: 24px; color: var(--gold); }
  .upload-zone .upload-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: .95rem;
    margin-bottom: .35rem;
    color: var(--text);
  }
  .upload-zone .upload-sub {
    font-size: .8rem;
    color: var(--text-secondary);
  }

  /* ── Loader ── */
  .loader {
    display: none;
    text-align: center;
    padding: 2.5rem;
  }
  .spinner {
    width: 32px; height: 32px;
    border: 3px solid var(--border);
    border-top-color: var(--gold);
    border-radius: 50%;
    animation: spin .7s linear infinite;
    margin: 0 auto .75rem;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loader-text { font-size: .85rem; color: var(--text-secondary); }

  /* ── Pedimento info bar ── */
  #ped-info {
    display: none;
    background: var(--navy);
    color: #fff;
    border-radius: 8px;
    padding: .85rem 1.25rem;
    font-size: .82rem;
    margin-bottom: 1rem;
    border-left: 4px solid var(--gold);
  }
  #ped-info strong { color: var(--gold); font-weight: 600; }
  #ped-info .sep { color: #475569; margin: 0 .75rem; }

  /* ── Summary cards ── */
  #summary { display: none; margin-bottom: 1.25rem; }
  .cards-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .75rem;
  }
  .stat-card {
    background: var(--surface);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--border);
  }
  .stat-card:nth-child(1)::before { background: var(--navy); }
  .stat-card:nth-child(2)::before { background: var(--gold); }
  .stat-card:nth-child(3)::before { background: var(--green); }
  .stat-card .stat-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    font-size: 1.75rem;
    line-height: 1;
    margin-bottom: .3rem;
  }
  .stat-card:nth-child(1) .stat-num { color: var(--navy); }
  .stat-card:nth-child(2) .stat-num { color: var(--gold); }
  .stat-card:nth-child(3) .stat-num { color: var(--green); }
  .stat-card .stat-label {
    font-size: .75rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  /* ── Controls ── */
  .controls {
    display: none;
    align-items: center;
    gap: .4rem;
    margin-bottom: .75rem;
    flex-wrap: wrap;
  }
  .filter-group {
    display: flex;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .filter-group button {
    padding: .45rem .85rem;
    border: none;
    background: transparent;
    cursor: pointer;
    font-size: .78rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: background .15s, color .15s;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
  }
  .filter-group button:not(:last-child) {
    border-right: 1px solid var(--border);
  }
  .filter-group button:hover { background: #f0f1f4; }
  .filter-group button.active {
    background: var(--navy);
    color: #fff;
  }
  .btn-export {
    margin-left: auto;
    padding: .45rem 1rem;
    border: none;
    border-radius: 6px;
    background: var(--green);
    color: #fff;
    font-size: .78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background .15s;
    display: flex;
    align-items: center;
    gap: .4rem;
  }
  .btn-export:hover { background: #15663a; }
  .btn-export svg { width: 14px; height: 14px; }

  /* ── Table ── */
  .table-wrap {
    display: none;
    overflow-x: auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: .8rem;
    font-variant-numeric: tabular-nums;
  }
  thead th {
    background: #F7F8FA;
    padding: .65rem .75rem;
    text-align: left;
    font-weight: 600;
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--text-secondary);
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
    position: sticky;
    top: 0;
    z-index: 1;
  }
  td {
    padding: .6rem .75rem;
    border-bottom: 1px solid #F0F1F4;
    color: var(--text);
  }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover { background: #FAFBFC; }
  tr.inc { background: var(--amber-bg); }
  tr.inc:hover { background: #FDF3DA; }
  tr.inc td { border-bottom-color: var(--amber-border); }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }

  .tag {
    display: inline-block;
    padding: .15rem .5rem;
    border-radius: 4px;
    font-size: .7rem;
    font-weight: 600;
    letter-spacing: .02em;
  }
  .tag-inc {
    background: #F59E0B;
    color: #fff;
  }
  .tag-no {
    background: #E9ECF1;
    color: #64748B;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .topbar { padding: 0 1rem; }
    .main { padding: 1.25rem 1rem 2rem; }
    .cards-row { grid-template-columns: 1fr; }
    .btn-export { margin-left: 0; margin-top: .25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .spinner { animation: none; }
  }
</style>
</head>
<body>

<div class="topbar">
  <h1><span>&#9670;</span>Analizador de Pedimentos</h1>
</div>

<div class="main">
  <div class="upload-zone" id="dropzone">
    <div class="upload-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V4m0 0l-4 4m4-4l4 4M4 20h16"/>
      </svg>
    </div>
    <div class="upload-title">Subir pedimento</div>
    <div class="upload-sub">Arrastra un PDF aquí o haz clic para seleccionar</div>
    <input type="file" id="fileInput" accept=".pdf">
  </div>

  <div class="loader" id="loader">
    <div class="spinner"></div>
    <div class="loader-text">Procesando pedimento…</div>
  </div>

  <div id="ped-info"></div>
  <div id="summary"></div>

  <div class="controls" id="controls">
    <div class="filter-group">
      <button class="active" data-filter="all">Todas</button>
      <button data-filter="inc">Con incrementables</button>
      <button data-filter="no">Sin incrementables</button>
    </div>
    <button class="btn-export" id="csv-btn">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 4v12m0 0l-4-4m4 4l4-4"/>
      </svg>
      Exportar Excel
    </button>
  </div>

  <div class="table-wrap" id="tableWrap"></div>
</div>

<script>
const dropzone = document.getElementById('dropzone');
const fileInput = document.getElementById('fileInput');
const loader = document.getElementById('loader');
let partidas = [];
let pedData = {};

dropzone.addEventListener('click', () => fileInput.click());
dropzone.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
dropzone.addEventListener('drop', e => {
  e.preventDefault(); dropzone.classList.remove('dragover');
  if (e.dataTransfer.files.length) upload(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => { if (fileInput.files.length) upload(fileInput.files[0]); });

async function upload(file) {
  loader.style.display = 'block';
  dropzone.style.display = 'none';
  document.getElementById('summary').style.display = 'none';
  document.getElementById('controls').style.display = 'none';
  document.getElementById('tableWrap').style.display = 'none';
  document.getElementById('ped-info').style.display = 'none';
  const fd = new FormData();
  fd.append('file', file);
  try {
    const res = await fetch('/parse', { method: 'POST', body: fd });
    if (!res.ok) { const e = await res.json(); throw new Error(e.detail || 'Error'); }
    pedData = await res.json();
    partidas = pedData.partidas;
    render();
  } catch(e) { alert('Error: ' + e.message); dropzone.style.display = 'block'; }
  loader.style.display = 'none';
}

function render(filter='all') {
  dropzone.style.display = 'none';

  const info = document.getElementById('ped-info');
  info.innerHTML = `<strong>Pedimento</strong> ${pedData.pedimento_num}<span class="sep">|</span><strong>Importador</strong> ${pedData.importador}`;
  info.style.display = 'block';

  const total = partidas.length;
  const conInc = partidas.filter(p => p.tiene_incrementables).length;
  const sum = document.getElementById('summary');
  sum.innerHTML = `<div class="cards-row">
    <div class="stat-card"><div class="stat-num">${total}</div><div class="stat-label">Total partidas</div></div>
    <div class="stat-card"><div class="stat-num">${conInc}</div><div class="stat-label">Con incrementables</div></div>
    <div class="stat-card"><div class="stat-num">${total - conInc}</div><div class="stat-label">Sin incrementables</div></div>
  </div>`;
  sum.style.display = 'block';

  document.getElementById('controls').style.display = 'flex';
  document.querySelectorAll('.filter-group button').forEach(b => {
    b.classList.toggle('active', b.dataset.filter === filter);
  });

  const filtered = partidas.filter(p => {
    if (filter === 'inc') return p.tiene_incrementables;
    if (filter === 'no') return !p.tiene_incrementables;
    return true;
  });

  const tc = pedData.tipo_cambio || 0;
  const wrap = document.getElementById('tableWrap');
  wrap.innerHTML = `<table>
    <thead><tr>
      <th>Partida</th><th>Descripción</th><th>Valor de Aduana</th><th>Piezas</th><th>Tipo de Cambio</th>
      <th>P.U USD</th><th>Valor Dlls</th><th>P.U MN</th>
    </tr></thead>
    <tbody>${filtered.map(p => {
      const puMn = p.precio_unitario;
      const puUsd = tc ? puMn / tc : 0;
      const valorDlls = tc ? p.val_aduana / tc : 0;
      return `<tr class="${p.tiene_incrementables ? 'inc' : ''}">
      <td>${p.sec}</td>
      <td>${p.descripcion}</td>
      <td class="num">$${p.val_aduana.toLocaleString()}</td>
      <td class="num">${p.cantidad}</td>
      <td class="num">${tc ? tc.toFixed(5) : '—'}</td>
      <td class="num">${tc ? '$' + puUsd.toFixed(5) : '—'}</td>
      <td class="num">${tc ? '$' + valorDlls.toFixed(2) : '—'}</td>
      <td class="num">$${puMn.toFixed(5)}</td>
    </tr>`;
    }).join('')}</tbody></table>`;
  wrap.style.display = 'block';
}

document.getElementById('controls').addEventListener('click', e => {
  const btn = e.target.closest('[data-filter]');
  if (btn) render(btn.dataset.filter);
  if (e.target.closest('#csv-btn')) exportExcel();
});

async function exportExcel() {
  const res = await fetch('/export', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(pedData),
  });
  const blob = await res.blob();
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `pedimento_${pedData.pedimento_num.replace(/\s+/g, '_')}.xlsx`;
  a.click();
}
</script>
</body>
</html>
